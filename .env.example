# ── OpenAI — powers Scout's LLM reasoning + tool-calling ─────────────────────
OPENAI_API_KEY=sk-...
# Model used for the agent loop (gpt-4o or gpt-4.1 recommended)
OPENAI_MODEL=gpt-4o

# ── ClickHouse Cloud — the analytical data warehouse Scout queries ───────────
CLICKHOUSE_HOST=https://your-instance.region.aws.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=...
CLICKHOUSE_DATABASE=default
