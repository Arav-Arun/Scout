# local dev & test scripts (but track the schema seeder + graph inspector — they
# are part of the feature, not throwaway local helpers). Ignore the directory's
# CONTENTS (not the dir itself) so the two files below can be re-included.
/scripts/*
!/scripts/seed_graph.mjs
!/scripts/ch_graph.mjs
!/scripts/ch_tables.mjs

